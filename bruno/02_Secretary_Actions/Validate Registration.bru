meta {
  name: Validate Registration
  type: http
  seq: 5
}

patch {
  url: {{gateway_url}}/api/members/{{created_student_id}}/registration-status
  body: json
  auth: bearer
}

auth:bearer {
  token: {{secretary_token}}
}

body:json {
  {
    "feePaid": true,
    "medicalCertificateProvided": true,
    "registrationValidated": true
  }
}

vars:pre-request {
  created_student_id: 6a2ec85056e837d434249d04
}

docs {
  Updates the registration status flags for a member.
  Accessible by Secretary and President.
}
