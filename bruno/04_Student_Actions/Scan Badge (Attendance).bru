meta {
  name: Scan Badge (Attendance)
  type: http
  seq: 2
}

post {
  url: {{gateway_url}}/api/badges/scan?badgeNumber=BADGE-123-456&lessonId={{created_lesson_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{student_token}}
}


docs {
  Simulates a student scanning their badge at a dance studio.
  This request sends a message via RabbitMQ for asynchronous processing.
}
