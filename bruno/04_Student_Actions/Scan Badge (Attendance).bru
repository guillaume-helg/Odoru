meta {
  name: Scan Badge (Attendance)
  type: http
  seq: 1
}

post {
  url: {{gateway_url}}/api/badges/scan?badgeNumber=BADGE-123-456&lessonId={{created_lesson_id}}
  body: none
  auth: bearer
}

params:query {
  badgeNumber: BADGE-123-456
  lessonId: {{created_lesson_id}}
}

auth:bearer {
