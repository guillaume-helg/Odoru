meta {
  name: Get Token President
  type: http
  seq: 1
}

post {
  url: {{keycloak_url}}/realms/odoru/protocol/openid-connect/token
  body: formUrlEncoded
  auth: none
}

body:form-urlencoded {
  client_id: odoru-services
  grant_type: password
  username: president
  password: admin
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("president_token", res.body.access_token);
    bru.setVar("refresh_token", res.body.refresh_token);
  }
}
