meta {
  name: Get Student Course Log
  type: http
  seq: 5
}

get {
  url: {{gateway_url}}/api/stats/students/{{created_student_id}}/attendance
  body: none
  auth: bearer
}

params:query {
  ~start: 2026-06-01T00:00:00
  ~end: 2026-06-30T23:59:59
}

auth:bearer {
  token: {{president_token}}
}


docs {
  Lists all courses for a specific student with presence/absence indication.
  Optional date range filters can be applied.
}
