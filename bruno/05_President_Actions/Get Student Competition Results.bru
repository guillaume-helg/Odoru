meta {
  name: Get Student Competition Results
  type: http
  seq: 4
}

get {
  url: {{gateway_url}}/api/stats/students/{{created_student_id}}/competitions
  body: none
  auth: bearer
}

params:query {
  ~start: 2026-06-01T00:00:00
  ~end: 2026-06-30T23:59:59
}

auth:bearer {
  token: {{president_token}}
}


docs {
  Lists competition results for a specific student.
  Optional date range filters can be applied.
}
